<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <insead_checkout>
            <insead_customcheckout>
                <!-- On by default; enable per website / store view as needed. -->
                <enabled>1</enabled>
                <!-- GST Declaration applies to programmes held in Singapore. -->
                <programme_in_singapore>1</programme_in_singapore>
            </insead_customcheckout>
        </insead_checkout>
    </default>
</config>
