<?xml version="1.0"?>
<!--
    E-invoicing / billing columns owned by this module.

    These columns back the custom INSEAD two-step checkout (billing + payment).
    `po_number` is intentionally NOT declared here — it is owned by
    Ewave_InseadIntegration. SIRET is stored in `uen`; SIREN is auto-derived and
    not persisted separately.
-->
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="quote">
        <column xsi:type="varchar" name="gender" nullable="true" length="32" comment="Customer Gender"/>
        <column xsi:type="varchar" name="nationality" nullable="true" length="2" comment="Customer Nationality (ISO country code)"/>
        <column xsi:type="varchar" name="job_industry" nullable="true" length="150" comment="Job Industry"/>
        <column xsi:type="varchar" name="financing_profile" nullable="true" length="50" comment="B2C or B2B"/>
        <column xsi:type="varchar" name="tax_registration_status" nullable="true" length="50" comment="Tax Registration Status"/>
        <column xsi:type="varchar" name="company_legal_name" nullable="true" length="255" comment="Company Full Legal Name"/>
        <column xsi:type="varchar" name="commercial_company_name" nullable="true" length="255" comment="Commercial Company Name"/>
        <column xsi:type="varchar" name="organization_type" nullable="true" length="100" comment="Organization Type"/>
        <column xsi:type="varchar" name="sector_of_activity" nullable="true" length="100" comment="Sector of Activity"/>
        <column xsi:type="varchar" name="uen" nullable="true" length="50" comment="UEN/Business Reg Number"/>
        <column xsi:type="varchar" name="vat_intracommunity" nullable="true" length="50" comment="VAT Intracommunity Number"/>
        <column xsi:type="varchar" name="vat_uae" nullable="true" length="50" comment="UAE VAT Number"/>
        <column xsi:type="varchar" name="gst_number" nullable="true" length="50" comment="Singapore GST Number"/>
        <column xsi:type="varchar" name="tax_id_number" nullable="true" length="50" comment="Tax ID Number"/>
        <column xsi:type="varchar" name="certificate_id" nullable="true" length="50" comment="Certificate ID"/>
        <column xsi:type="varchar" name="duns_number" nullable="true" length="50" comment="DUNS Number"/>
        <column xsi:type="varchar" name="routing_address" nullable="true" length="255" comment="Routing Address"/>
        <column xsi:type="varchar" name="tax_exempt_file" nullable="true" length="255" comment="Tax Exempt Certificate File"/>
        <column xsi:type="varchar" name="invoice_recipient_firstname" nullable="true" length="100" comment="Invoice Recipient First Name"/>
        <column xsi:type="varchar" name="invoice_recipient_lastname" nullable="true" length="100" comment="Invoice Recipient Last Name"/>
        <column xsi:type="varchar" name="invoice_email" nullable="true" length="255" comment="Invoice Email"/>
        <column xsi:type="varchar" name="reg_type_label" nullable="true" length="100" comment="Registration Type Label"/>
        <column xsi:type="varchar" name="reg_type_value" nullable="true" length="100" comment="Registration Type Value"/>
        <column xsi:type="varchar" name="credit_consumption_code" nullable="true" length="100" comment="Credit Consumption Code"/>
        <column xsi:type="varchar" name="gst_declaration" nullable="true" length="50" comment="GST Declaration selection"/>
        <column xsi:type="varchar" name="residency_declaration" nullable="true" length="10" comment="Self-funded residency declaration (agree/disagree)"/>
    </table>
    <table name="sales_order">
        <column xsi:type="varchar" name="gender" nullable="true" length="32" comment="Customer Gender"/>
        <column xsi:type="varchar" name="nationality" nullable="true" length="2" comment="Customer Nationality (ISO country code)"/>
        <column xsi:type="varchar" name="job_industry" nullable="true" length="150" comment="Job Industry"/>
        <column xsi:type="varchar" name="financing_profile" nullable="true" length="50" comment="B2C or B2B"/>
        <column xsi:type="varchar" name="tax_registration_status" nullable="true" length="50" comment="Tax Registration Status"/>
        <column xsi:type="varchar" name="company_legal_name" nullable="true" length="255" comment="Company Full Legal Name"/>
        <column xsi:type="varchar" name="commercial_company_name" nullable="true" length="255" comment="Commercial Company Name"/>
        <column xsi:type="varchar" name="organization_type" nullable="true" length="100" comment="Organization Type"/>
        <column xsi:type="varchar" name="sector_of_activity" nullable="true" length="100" comment="Sector of Activity"/>
        <column xsi:type="varchar" name="uen" nullable="true" length="50" comment="UEN/Business Reg Number"/>
        <column xsi:type="varchar" name="vat_intracommunity" nullable="true" length="50" comment="VAT Intracommunity Number"/>
        <column xsi:type="varchar" name="vat_uae" nullable="true" length="50" comment="UAE VAT Number"/>
        <column xsi:type="varchar" name="gst_number" nullable="true" length="50" comment="Singapore GST Number"/>
        <column xsi:type="varchar" name="tax_id_number" nullable="true" length="50" comment="Tax ID Number"/>
        <column xsi:type="varchar" name="certificate_id" nullable="true" length="50" comment="Certificate ID"/>
        <column xsi:type="varchar" name="duns_number" nullable="true" length="50" comment="DUNS Number"/>
        <column xsi:type="varchar" name="routing_address" nullable="true" length="255" comment="Routing Address"/>
        <column xsi:type="varchar" name="tax_exempt_file" nullable="true" length="255" comment="Tax Exempt Certificate File"/>
        <column xsi:type="varchar" name="invoice_recipient_firstname" nullable="true" length="100" comment="Invoice Recipient First Name"/>
        <column xsi:type="varchar" name="invoice_recipient_lastname" nullable="true" length="100" comment="Invoice Recipient Last Name"/>
        <column xsi:type="varchar" name="invoice_email" nullable="true" length="255" comment="Invoice Email"/>
        <column xsi:type="varchar" name="reg_type_label" nullable="true" length="100" comment="Registration Type Label"/>
        <column xsi:type="varchar" name="reg_type_value" nullable="true" length="100" comment="Registration Type Value"/>
        <column xsi:type="varchar" name="credit_consumption_code" nullable="true" length="100" comment="Credit Consumption Code"/>
        <column xsi:type="varchar" name="gst_declaration" nullable="true" length="50" comment="GST Declaration selection"/>
        <column xsi:type="varchar" name="residency_declaration" nullable="true" length="10" comment="Self-funded residency declaration (agree/disagree)"/>
    </table>
</schema>
